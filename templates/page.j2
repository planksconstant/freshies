<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- Reads the title from frontmatter, falls back to default -->
    <title>{{ page.frontmatter.title | default("PESU Freshers Hub") }}</title>
    <!-- Reads description from frontmatter for SEO optimization -->
    <meta name="description" content="{{ page.frontmatter.description }}">
    <style>
        body { 
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; 
            line-height: 1.6; 
            max-width: 850px; 
            margin: 40px auto; 
            padding: 0 20px; 
            color: #333;
            background-color: #fafafa;
        }
        main {
            background: #fff;
            padding: 40px;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        }
        h1 { border-bottom: 2px solid #0056b3; padding-bottom: 10px; color: #0056b3; }
        h2 { border-bottom: 1px solid #ddd; padding-bottom: 8px; margin-top: 30px; color: #222; }
        table { width: 100%; border-collapse: collapse; margin: 20px 0; }
        th, td { border: 1px solid #ddd; padding: 12px; text-align: left; }
        th { background-color: #f4f4f4; }
        blockquote { background: #f0f7ff; border-left: 4px solid #0056b3; padding: 15px; margin: 20px 0; font-style: italic; }
        hr { border: 0; height: 1px; background: #ddd; margin: 40px 0; }
    </style>
</head>
<body>
    <main>
        {{ page.content }}
    </main>
</body>
</html>
